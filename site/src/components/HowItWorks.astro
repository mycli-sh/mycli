---
const steps = [
  {
    number: "1",
    title: "Install",
    description: "Install a library from the registry or add a git-backed source.",
    code: `$ my library install kubernetes
Installed kubernetes (12 commands)

$ my source add https://github.com/user/ops-tools.git
Added source "ops-tools" (2 libraries)`,
  },
  {
    number: "2",
    title: "Run",
    description: "Run commands directly as top-level subcommands with full arg parsing.",
    code: `$ my kubernetes port-forward svc/my-service -p 8080
Forwarding svc/my-service:8080 → localhost:8080

$ my ops deploy api -e production
Deploying api to production...
Deploy complete.`,
  },
  {
    number: "3",
    title: "Create your own",
    description: "Author commands as YAML specs, push to the registry, and share them.",
    code: `schemaVersion: 1
kind: command

metadata:
  name: greet
  slug: greet
  description: Greet someone

steps:
  - name: greet
    run: echo 'Hello, {{.args.name}}!'

$ my cli push -f command.yaml
Published version 1 (hash: e5f6a7b8)`,
  },
];
---

<section id="how-it-works" class="py-20">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">How it works</h2>
      <p class="mt-4 text-lg text-zinc-400">
        From installation to creating your own.
      </p>
    </div>

    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      {steps.map((step) => (
        <div class="group">
          <div class="mb-4 flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-violet-500/20 text-sm font-bold text-violet-400">
              {step.number}
            </span>
            <h3 class="text-xl font-semibold text-white">{step.title}</h3>
          </div>
          <p class="mb-4 text-sm text-zinc-400">{step.description}</p>
          <div class="overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900">
            <pre class="overflow-x-auto p-4 font-mono text-xs leading-relaxed text-zinc-300"><code>{step.code}</code></pre>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
