        <div class="mt-4 text-zinc-500"># Run from any machine</div>
        <div><span class="text-violet-400">$</span> <span class="text-zinc-200">my cli run deploy -- production</span></div>
        <div class="text-zinc-300">Deploying to production...</div>
        <div class="text-zinc-300">Deploy complete.</div>
        <div class="mt-4"><span class="text-violet-400">$</span> <span class="animate-pulse text-zinc-400">|</span></div>
