{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycli.sh/schema/command-v1.schema.json",
  "title": "CommandSpec v1",
  "description": "Schema for mycli command specification v1",
  "type": "object",
  "required": ["schemaVersion", "kind", "metadata", "steps"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "command"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "slug"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "uniqueItems": true
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shell": {
          "type": "string",
          "enum": ["/bin/sh", "/bin/bash", "/bin/zsh", "/usr/bin/env"]
        },
        "timeout": {
          "type": "string",
          "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)+$"
        },
        "env": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "templateDelimiters": {
          "type": "array",
          "description": "Custom left/right delimiters for template expressions (default: ['{{', '}}'])",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "args": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "positional": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              },
              "required": {
                "type": "boolean",
                "default": true
              },
              "default": {
                "type": "string"
              }
            }
          }
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "short": {
                "type": "string",
                "pattern": "^[a-zA-Z]$"
              },
              "description": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["string", "bool", "int"],
                "default": "string"
              },
              "default": {},
              "required": {
                "type": "boolean",
                "default": false
              }
            }
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "run"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "run": {
            "type": "string",
            "minLength": 1
          },
          "env": {
            "type": "object",
            "propertyNames": {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "timeout": {
            "type": "string",
            "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)+$"
          },
          "continueOnError": {
            "type": "boolean"
          },
          "shell": {
            "type": "string",
            "enum": ["/bin/sh", "/bin/bash", "/bin/zsh", "/usr/bin/env"]
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requireConfirmation": {
          "type": "boolean"
        },
        "allowedExecutables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
